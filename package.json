{
  "name": "@crosslybot/mcp-server",
  "version": "0.2.0",
  "description": "MCP server for Crosslybot — cross-posting to Telegram, VK, Max via Claude Desktop, Cursor, Cline and other MCP clients",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "crosslybot-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "express": "^4.21.2",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "crosslybot",
    "telegram",
    "vk",
    "max",
    "cross-posting",
    "claude",
    "cursor",
    "cline"
  ],
  "author": "Crosslybot",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/antiblef/Crosslybot-mcp"
  },
  "homepage": "https://mcp.crosslybot.ru"
}
